# Django Backend
SECRET_KEY=change-me-to-a-random-50-char-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (leave blank for SQLite in development)
DB_NAME=
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
# Or use a DATABASE_URL instead:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hos_db

# OpenRouteService API key (required for route calculations)
# Get a free key at https://openrouteservice.org/dev/#/signup
ORS_API_KEY=

# CORS (comma-separated origins)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Frontend
VITE_API_URL=http://localhost:8000
